---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";

const publishedTeamMembers = await getCollection("team", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
---

<Layout title="About">
  <Container>
    <Sectionhead>
      <Fragment slot="title">実行委員会について</Fragment>
      <Fragment slot="desc">スクラム祭りを作り上げるメンバーたちです。</Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">
        スクラム祭り コンセプト
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        ここにスクラム祭りのコンセプトが入ります。参加者全員が楽しみながらスクラムの価値と実践を学び、現場に持ち帰ることを目的としています。多様なバックグラウンドを持つ人々が交流し、新しいアイデアを生み出す場を提供します。
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-4xl mt-12">
      {
        publishedTeamMembers.map((teamMemberEntry) => (
          <div class="group">
            <div class="w-full aspect-square overflow-hidden rounded-sm bg-slate-100 border border-slate-200">
              <img
                src={teamMemberEntry.data.avatar.src}
                alt={teamMemberEntry.data.avatar.alt}
                class="w-full h-full object-cover transition group-hover:-translate-y-1 group-hover:shadow-xl"
              />
            </div>

            <div class="mt-4 text-center">
              <h2 class="text-lg text-gray-800">{teamMemberEntry.data.name}</h2>
              <h3 class="text-sm text-slate-500">
                {teamMemberEntry.data.title}
              </h3>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</Layout>
