---
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">お問い合わせ</Fragment>
      <Fragment slot="desc">お気軽にご連絡ください。</Fragment>
    </Sectionhead>

    <div class="mx-auto max-w-2xl mt-16">
      <div class="bg-slate-50 p-8 md:p-12 rounded-xl border border-slate-100 text-center">
        <p class="text-lg text-slate-600 mb-4">
          お問い合わせは以下のメールアドレスまでお願いいたします。
        </p>
        <p class="text-xl md:text-2xl font-bold text-indigo-600 tracking-wider">
          scrummatsuri(at)googlegroups.com
        </p>
        <p class="text-sm text-slate-500 mt-3">
          ※ (at) を @ に置き換えて送信してください。
        </p>
      </div>
    </div>
  </Container>
