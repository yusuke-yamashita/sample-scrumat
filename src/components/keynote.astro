---
const keynotes = [
  {
    name: "ダミー 太郎",
    role: "アジャイルコーチ / ダミー株式会社",
    bio: "ここにKeynoteスピーカーの紹介文が入ります。アジャイルやスクラムの最前線で活躍するエキスパートとして、実践的な知見を共有します。",
    imageUrl: "https://api.dicebear.com/7.x/avataaars/svg?seed=Felix",
  },
  {
    name: "ダミー 花子",
    role: "プロダクトオーナー / 株式会社サンプル",
    bio: "ここに2人目のKeynoteスピーカーの紹介文が入ります。プロダクト開発とスクラムの融合について、具体的な事例を交えて語ります。",
    imageUrl: "https://api.dicebear.com/7.x/avataaars/svg?seed=Aneka",
  }
];
---

<div class="mt-16 md:mt-24 mb-16 md:mb-24">
  <div class="text-center">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Keynote スピーカー
    </h2>
    <p class="text-lg mt-4 text-slate-600">
      スクラムの最前線で活躍するスピーカーをお招きします。
    </p>
  </div>

  <div class="grid sm:grid-cols-2 gap-10 mt-16 max-w-4xl mx-auto">
    {
      keynotes.map((speaker) => (
        <div class="flex flex-col items-center text-center gap-4">
          <div class="w-40 h-40 rounded-full overflow-hidden bg-slate-100 shadow-md border border-slate-200">
            <img src={speaker.imageUrl} alt={speaker.name} class="w-full h-full object-cover" />
          </div>
          <div>
            <h3 class="font-semibold text-2xl">{speaker.name}</h3>
            <p class="text-indigo-500 font-medium mt-1">{speaker.role}</p>
            <p class="text-slate-500 mt-4 leading-relaxed">{speaker.bio}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>